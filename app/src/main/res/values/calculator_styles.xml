<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Calculator Button Base Style -->
    <style name="CalculatorButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textColor">@color/calc_button_number_text</item>
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/calc_button_number</item>
        <item name="cornerRadius">100dp</item>
    </style>

    <style name="CalculatorButtonStyle.Operator" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/calc_button_operator</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalculatorButtonStyle.Action" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/calc_button_special</item>
        <item name="android:textColor">@color/calc_button_special_text</item>
    </style>

    <style name="CalculatorButtonStyle.Scientific" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/calc_button_scientific</item>
        <item name="android:textColor">@color/calc_button_scientific_text</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
